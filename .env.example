NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3050
WEB_PORT=3200
ADMIN_PORT=3100
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8001
AI_SERVICE_BASE_URL=http://127.0.0.1:8001
JWT_SECRET=campusfit_dev_secret
ADMIN_EMAIL=ops@campusfit.ai
ADMIN_PASSWORD=change-me-in-production
API_DATA_MODE=auto
LOG_LEVEL=INFO
CORS_ORIGIN=http://127.0.0.1:3200,http://localhost:3200,http://127.0.0.1:3100,http://localhost:3100
SWAGGER_ENABLED=true
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3050/api/v1
NEXT_PUBLIC_AI_BASE_URL=http://127.0.0.1:8001
NEXT_PUBLIC_WEB_APP_NAME=CampusFit AI
API_IMAGE=campusfit-api:latest
WEB_IMAGE=campusfit-web:latest
ADMIN_IMAGE=campusfit-admin:latest
AI_SERVICE_IMAGE=campusfit-ai-service:latest
TLS_CERT_DIR=./certs

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=campusfit
POSTGRES_PASSWORD=campusfit_dev
POSTGRES_DB=campusfit_ai
# 生产环境如需强制 SSL，可追加 ?sslmode=require
DATABASE_URL=postgresql://campusfit:campusfit_dev@127.0.0.1:5432/campusfit_ai

REDIS_URL=redis://127.0.0.1:6379/0
AI_PROVIDER=mock
AI_MODEL=campusfit-mock
AI_CORS_ORIGINS=http://127.0.0.1:3200,http://localhost:3200
OPENAI_BASE_URL=
OPENAI_API_KEY=

AUTH_EMAIL_PROVIDER=mock
AUTH_EMAIL_DEV_CODE_VISIBLE=false
AUTH_OTP_TTL_SECONDS=600
AUTH_OTP_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CampusFit AI <no-reply@example.com>
