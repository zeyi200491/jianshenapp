{
  "name": "@campusfit/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm --prefix ../../packages/rule-engine run build",
    "prebuild": "npm run prisma:generate && npm --prefix ../../packages/rule-engine run build",
    "prestart": "npm run prisma:generate && npm --prefix ../../packages/rule-engine run build",
    "pretest": "npm --prefix ../../packages/rule-engine run build",
    "dev": "ts-node src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.cjs",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@campusfit/rule-engine": "file:../../packages/rule-engine",
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.4.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.0",
    "helmet": "^8.0.0",
    "@prisma/client": "^5.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^6.9.16",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.5",
    "jest": "^29.7.0",
    "prisma": "^5.13.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
